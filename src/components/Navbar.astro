<header class="navbar">
  <div class="container">
    <div class="inner-nav">
      <a href="#" class="nav-logo">Abraham Tovar</a>
      <ul class="nav-links">
        <li><a href="#works">Works</a></li>
        <li class="source-link">
          <img
            src="/images/github-logo.svg"
            alt="Github Logo"
            class="github-icon"
          />
          <a href="https://github.com/lagooncode" target="_blank">Source</a>
        </li>
        <li>
          <button class="theme-toggle" id="theme-toggle">🌙</button>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  .navbar {
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    transition: background-color 0.3s ease;
  }

  .inner-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-weight: 600;
    font-size: var(--text-base);
    position: relative;
    display: inline-block;
  }

  .nav-logo::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-logo:hover::after {
    width: 100%;
  }

  .nav-links {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .nav-links a {
    font-weight: 400;
    font-size: var(--text-sm);
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .source-link {
    display: flex;
    gap: 0.3rem;
    align-items: center;
  }

  .github-icon {
    width: clamp(1rem, 2vw, 1.5rem);
    height: auto;
  }

  :root.dark .github-icon {
    filter: invert(1);
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-base);
    padding: 0;
    line-height: 1;
  }

</style>

<script is:inline>
  const btn = document.getElementById("theme-toggle");
  const metaTheme = document.querySelector('meta[name="theme-color"]');

  function setTheme(isDark) {
    if (isDark) {
      document.documentElement.classList.add("dark");
      btn.textContent = "☀️";
      if (metaTheme) metaTheme.setAttribute("content", "#0a0a0a");
    } else {
      document.documentElement.classList.remove("dark");
      btn.textContent = "🌙";
      if (metaTheme) metaTheme.setAttribute("content", "#fafafa");
    }
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  setTheme(localStorage.getItem("theme") === "dark");

  btn.addEventListener("click", () => {
    const isDark = !document.documentElement.classList.contains("dark");
    setTheme(isDark);
  });
</script>
