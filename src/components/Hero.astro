<header class="hero">
  <div class="container">
    <div class="hero-section">
      <div class="hero-text">
        <p class="hero-greetings">Hey, <span class="wave">👋🏼</span> !</p>
        <h1 class="hero-name">I'm <span class="accent">Abraham Tovar</span></h1>
        <p class="hero-typewritter">
          <span id="typewriter"></span>
          <span class="cursor">|</span>
        </p>
      </div>
      <div class="hero-photo">
        <img
          src="/images/hero-profile-image.jpg"
          class="hero-picture"
          alt="Abraham Tovar's profile photo"
        />
      </div>
    </div>
  </div>
</header>

<style>
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hero-greetings {
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .hero-name {
    font-weight: 800;
    font-size: var(--text-xl);
  }

  .accent {
    color: var(--color-accent);
  }

  .hero-typewritter {
    font-weight: 600;
    font-size: var(--text-lg);
  }

  .hero-picture {
    width: clamp(6rem, 12vw, 9rem);
    height: clamp(6rem, 12vw, 9rem);
    border-radius: 50%;
    object-fit: cover;
  }

  .cursor {
    color: #9ca3af;
    animation: parpadeo 1s infinite;
  }

  @keyframes parpadeo {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .wave {
    display: inline-block;
    animation: saludar 1.5s ease-in-out 1;
    transform-origin: 70% 70%;
  }

  @keyframes saludar {
    0%   { transform: rotate(0deg); }
    20%  { transform: rotate(20deg); }
    40%  { transform: rotate(-10deg); }
    60%  { transform: rotate(20deg); }
    80%  { transform: rotate(-5deg); }
    100% { transform: rotate(0deg); }
  }
</style>

<script is:inline>
  const palabras = [
    "Software Developer",
    "Cloud Enthusiast",
    "Lifelong Learner",
  ];
  const elemento = document.getElementById("typewriter");
  let indicePalabra = 0;
  let indiceLetra = 0;
  let borrando = false;

  function escribir() {
    const palabraActual = palabras[indicePalabra];

    if (!borrando) {
      elemento.textContent = palabraActual.slice(0, indiceLetra + 1);
      indiceLetra++;
      if (indiceLetra === palabraActual.length) {
        borrando = true;
        setTimeout(escribir, 1500);
        return;
      }
    } else {
      elemento.textContent = palabraActual.slice(0, indiceLetra - 1);
      indiceLetra--;
      if (indiceLetra === 0) {
        borrando = false;
        indicePalabra = (indicePalabra + 1) % palabras.length;
      }
    }

    setTimeout(escribir, borrando ? 60 : 100);
  }

  escribir();
</script>