---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Fullstack Developer passionate about building clean web experiences. Cloud enthusiast and lifelong learner."
    />
    <meta
      name="keywords"
      content="fullstack developer, javascript, react, astro, cloud, aws"
    />
    <meta name="author" content="Abraham Tovar" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌊</text></svg>"
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geologica:wght,CRSV@100..900,0&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #fafafa;
    --color-text: #1a1a1a;
    --color-accent: #0ea5e9;
    --text-sm: clamp(0.9rem, 1.5vw, 1rem);
    --text-base: clamp(1rem, 2vw, 1.2rem);
    --text-md: clamp(1.2rem, 2vw, 1.4rem);
    --text-lg: clamp(1.8rem, 4vw, 2.6rem);
    --text-xl: clamp(2.4rem, 5vw, 3.4rem);
    --padding-x: clamp(1rem, 3vw, 1.5rem);
    --section-padding-top: clamp(2.5rem, 5vw, 4rem);
    --section-padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  :root.dark {
    --color-bg: #0a0a0a;
    --color-text: #e8e8e0;
  }

  * {
    scroll-behavior: smooth;
  }

  body {
    font-family: Geologica, sans-serif;
    background-color: var(--color-bg);
    color: var(--color-text);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  ul {
    list-style: none;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 var(--padding-x);
  }
</style>
